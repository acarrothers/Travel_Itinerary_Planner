{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --no-frozen-lockfile --prod=false"
  },
  "deploy": {
    "startCommand": "pnpm --filter @trip-itinerary/api migrate && pnpm --filter @trip-itinerary/api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
