{
  "name": "@chatr/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(api) add eslint\"",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@chatr/core": "workspace:*",
    "@chatr/ai-orchestration": "workspace:*",
    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "dotenv": "^16.4.5",
    "@fastify/cors": "^9.0.1",
    "tsx": "^4.16.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0"
  }
}