# --- AI providers (model orchestration layer routes across any of these) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
# Routing policy maps each task -> provider/model; override in apps/api/src/aiSetup.ts

# --- Maps & POI (decided: Google Maps Platform for rendering; Foursquare for POI) ---
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
FOURSQUARE_API_KEY=

# --- Anchor affiliate partner (decided: Viator) ---
VIATOR_AFFILIATE_ID=
VIATOR_API_KEY=

# --- Data & API ---
DATABASE_URL=postgresql://tripplanner:tripplanner@localhost:5432/tripplanner
API_BASE_URL=http://localhost:4000

# --- User auth (JWT) — set a long random string in production ---
JWT_SECRET=

# --- Email (verification + password reset) ---
APP_WEB_URL=http://localhost:3000     # base URL used in verify/reset links
RESEND_API_KEY=                       # set to send real emails via Resend; blank = log to console (dev)
EMAIL_FROM=Trip Itinerary Planner <onboarding@resend.dev>
REQUIRE_EMAIL_VERIFICATION=false      # true = block trip creation until email is verified

# --- SSO (optional; leave blank to hide the Google/Apple buttons) ---
GOOGLE_CLIENT_ID=                 # server: verifies Google ID-token audience
APPLE_CLIENT_ID=                  # server: Apple Services ID (audience)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=     # web: Google Sign-In button
NEXT_PUBLIC_APPLE_CLIENT_ID=      # web: Apple Sign-In (Services ID)
NEXT_PUBLIC_APPLE_REDIRECT_URI=   # web: must match your Apple config (your web URL)

# --- CMS RBAC (leave unset for dev mode = full access) ---
# Map API keys to roles: admin | partnerships_manager | approver | analyst
APP_API_KEYS={"admin-key":"admin","pm-key":"partnerships_manager","analyst-key":"analyst"}
